# Firebase Configuration for PDF Toolkit Licensing
# Copy this file to .env and fill in your actual values.
#
# Get these from Firebase Console → Project Settings → General → Your apps
# See firebase_setup.md for step-by-step instructions.

FIREBASE_PROJECT_ID=your-project-id-here
FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project-id-here.firebaseapp.com

# Admin email — the only account allowed to manage licenses
ADMIN_EMAIL=Adnan@thothica.com
